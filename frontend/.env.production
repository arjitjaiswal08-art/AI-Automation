# Production Environment Variables
# This will be overridden by Vercel environment variables

# Backend API URL - Update this after deploying backend to Render
VITE_API_URL=https://your-backend.onrender.com

# Instructions:
# 1. Deploy backend to Render first
# 2. Get your backend URL (e.g., https://ai-unica-backend.onrender.com)
# 3. Add VITE_API_URL to Vercel environment variables with your actual backend URL
# 4. Redeploy frontend on Vercel
