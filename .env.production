# Production Environment Configuration
# Copy this file to .env and update with your actual values

# Database - Use PostgreSQL for production or SQLite for simple deployments
DATABASE_URL=sqlite:///./codepilot_ai.db
# For PostgreSQL: postgresql://user:password@host:port/database

# API Keys (REQUIRED)
OPENAI_API_KEY=your-openai-api-key-here
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Use Local AI with Ollama (set to false if using cloud AI only)
USE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434

# JWT Authentication (IMPORTANT: Change these!)
SECRET_KEY=CHANGE-THIS-TO-A-RANDOM-SECRET-KEY-IN-PRODUCTION
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Environment
ENVIRONMENT=production
DEBUG=False

# CORS Origins (Update with your frontend domain)
CORS_ORIGINS=["https://your-domain.com","https://www.your-domain.com"]

# Rate Limiting
RATE_LIMIT_FREE_TIER=50
RATE_LIMIT_PRO_TIER=unlimited

# Model Configuration
DEFAULT_MODEL=gpt-4o-mini
DEFAULT_EMBEDDING_MODEL=text-embedding-3-large

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379
